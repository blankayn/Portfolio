<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>My Portfolio —</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --pink:#E8527A;
  --pink-light:#F5C0CE;
  --pink-pale:#FDE8EF;
  --teal:#5DCFC8;
  --teal-light:#B2EAE6;
  --teal-pale:#E1F7F5;
  --dark:#1A1A1A;
  --mid:#666;
  --light:#F8F5F0;
  --white:#FFFFFF;
  --border:#E8E4DE;
}
html{scroll-behavior:smooth;}
body{
  font-family:'DM Sans',sans-serif;
  background:var(--light);
  color:var(--dark);
  overflow-x:hidden;
}

/* ─── NAV ─── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;justify-content:space-between;align-items:center;
  padding:1.2rem 3rem;
  background:rgba(248,245,240,0.92);
  backdrop-filter:blur(8px);
  border-bottom:1px solid var(--border);
}
.nav-logo{
  font-family:'Bebas Neue',cursive;
  font-size:1.4rem;letter-spacing:3px;
  color:var(--dark);
}
.nav-links{display:flex;gap:2rem;list-style:none;}
.nav-links a{
  font-size:11px;letter-spacing:2.5px;text-transform:uppercase;
  color:var(--mid);text-decoration:none;
  transition:color .2s;
}
.nav-links a:hover{color:var(--pink);}
.nav-cta{
  font-size:11px;letter-spacing:2px;text-transform:uppercase;
  background:var(--pink);color:#fff;
  border:none;padding:.6rem 1.4rem;cursor:pointer;
  transition:background .2s;
}
.nav-cta:hover{background:#c93d63;}

/* Hamburger Menu */
.nav-menu{
  display:none;flex-direction:column;gap:5px;
  background:none;border:none;cursor:pointer;z-index:101;
}
.nav-menu span{
  width:24px;height:2px;background:var(--dark);
  transition:all .3s ease;
}
.nav-menu.active span:nth-child(1){transform:rotate(45deg) translate(10px, 10px);}
.nav-menu.active span:nth-child(2){opacity:0;}
.nav-menu.active span:nth-child(3){transform:rotate(-45deg) translate(8px, -8px);}

/* ─── SECTION WRAPPER ─── */
section{min-height:100vh;position:relative;}

/* ─── COVER ─── */
#cover{
  background:var(--white);
  display:grid;grid-template-columns:1fr 1fr;
  padding-top:64px;
  overflow:hidden;
}
.cover-left{
  position:relative;
  padding:3rem 3rem 3rem 5rem;
  display:flex;flex-direction:column;
  justify-content:space-between;
  border-right:1px solid var(--border);
}
.cover-header-labels{
  display:flex;justify-content:space-between;
  font-size:10px;letter-spacing:3px;text-transform:uppercase;
  color:var(--mid);
}
.cover-header-labels span{display:flex;align-items:center;gap:8px;}
.cover-header-labels .line{display:inline-block;width:20px;height:1px;background:var(--dark);}

/* Vertical name text */
.side-text-left{
  position:absolute;left:1.8rem;top:50%;
  transform:translateY(-50%) rotate(-90deg);
  font-size:9px;letter-spacing:4px;text-transform:uppercase;
  color:var(--mid);white-space:nowrap;transform-origin:center;
}

/* Big overlapping title */
.title-wrap{
  position:relative;
  display:flex;align-items:center;
  justify-content:center;
  flex:1;
  margin:2rem 0;
}
.big-title{
  font-family:'Bebas Neue',cursive;
  font-size:9.5rem;line-height:.87;
  letter-spacing:4px;color:var(--dark);
  display:grid;grid-template-columns:1fr 1fr;
  z-index:3;position:relative;
  user-select:none;
}
.teal-block{
  position:absolute;
  width:180px;height:230px;
  background:var(--teal);
  z-index:1;
  top:50%;left:50%;
  transform:translate(-42%,-48%);
}
.photo-placeholder{
  position:absolute;
  width:180px;height:230px;
  z-index:2;
  top:50%;left:50%;
  transform:translate(-42%,-48%);
  overflow:hidden;
}
.photo-placeholder svg{width:100%;height:100%;}
.pink-bar{
  position:absolute;
  width:55px;height:14px;
  background:var(--pink);
  z-index:4;
  bottom:36%;left:38%;
}
.cover-bottom{padding-top:1rem;}
.cover-tag{
  font-size:11px;letter-spacing:4px;text-transform:uppercase;
  color:var(--dark);margin-bottom:.5rem;
}
.cover-tagline{font-size:13px;color:var(--mid);line-height:1.7;}

/* Right panel — table of contents */
.cover-right{
  background:var(--white);
  padding:3rem;
  display:flex;flex-direction:column;
  gap:2rem;
}
.side-text-right{
  position:absolute;right:1.8rem;top:50%;
  transform:translateY(-50%) rotate(90deg);
  font-size:9px;letter-spacing:4px;text-transform:uppercase;
  color:var(--pink);white-space:nowrap;
}
.toc-title{
  font-size:9px;letter-spacing:3px;text-transform:uppercase;
  color:var(--mid);margin-bottom:1rem;
}
.toc-item{
  display:flex;justify-content:space-between;align-items:center;
  padding:.6rem 0;
  border-bottom:1px solid var(--border);
  font-size:13px;color:var(--dark);
  cursor:pointer;transition:color .2s;
}
.toc-item:hover{color:var(--pink);}
.toc-num{font-size:11px;color:var(--mid);}
.cover-image-thumb{
  width:100%;height:180px;
  background:var(--teal-pale);
  position:relative;overflow:hidden;
  margin-top:1rem;
}
.cover-image-thumb .inner-teal{
  position:absolute;top:20px;right:20px;
  width:80px;height:100px;background:var(--teal);opacity:.5;
}
.cover-image-thumb .inner-pink{
  position:absolute;bottom:20px;left:20px;
  width:60px;height:8px;background:var(--pink);
}
.toc-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--mid);}

/* ─── ABOUT ─── */
#about{
  background:var(--white);
  padding-top:64px;
  min-height:100vh;
}
.about-inner{
  display:grid;grid-template-columns:1fr 1fr;
  min-height:calc(100vh - 64px);
}
.about-left{
  padding:4rem 3rem 4rem 5rem;
  border-right:1px solid var(--border);
  position:relative;display:flex;flex-direction:column;gap:2.5rem;
}
.section-vert-label{
  position:absolute;left:1.5rem;top:50%;
  transform:translateY(-50%) rotate(-90deg);
  font-family:'Bebas Neue',cursive;
  font-size:5.5rem;letter-spacing:6px;
  color:var(--border);
  white-space:nowrap;
  pointer-events:none;
}
.section-tag{
  font-size:10px;letter-spacing:3px;text-transform:uppercase;
  color:var(--pink);margin-bottom:.4rem;
}
.about-heading{
  font-family:'Bebas Neue',cursive;
  font-size:3.5rem;letter-spacing:2px;line-height:.95;
  color:var(--dark);
}
.about-text{font-size:13.5px;line-height:1.8;color:var(--mid);max-width:400px;}
.about-img-block{
  width:100%;height:200px;
  background:var(--pink-pale);
  position:relative;overflow:hidden;
}
.about-img-inner{
  position:absolute;right:0;top:0;bottom:0;width:65%;
  background:var(--pink-light);
}
.about-img-accent{
  position:absolute;left:20px;bottom:20px;
  width:40px;height:5px;background:var(--pink);
}
.about-stats{display:flex;gap:2rem;}
.stat{border-left:3px solid var(--teal);padding-left:.8rem;}
.stat-num{
  font-family:'Bebas Neue',cursive;font-size:2rem;
  color:var(--dark);line-height:1;
}
.stat-label{font-size:11px;color:var(--mid);letter-spacing:1px;}

/* Education panel */
.about-right{
  padding:4rem 3rem 4rem 3rem;
  display:flex;flex-direction:column;gap:2.5rem;
  position:relative;
}
.edu-img-block{
  width:100%;height:160px;
  background:var(--teal-pale);
  position:relative;overflow:hidden;
}
.edu-img-inner{
  position:absolute;right:0;top:0;bottom:0;width:55%;
  background:var(--teal-light);
}
.edu-img-accent{
  position:absolute;left:20px;top:20px;
  width:5px;height:50px;background:var(--teal);
}
.edu-heading{
  font-family:'Bebas Neue',cursive;
  font-size:3.5rem;letter-spacing:2px;
  color:var(--dark);line-height:.95;
}
.edu-item{
  display:flex;gap:1.5rem;align-items:flex-start;
  padding:.8rem 0;border-bottom:1px solid var(--border);
}
.edu-year{
  font-size:10px;letter-spacing:2px;text-transform:uppercase;
  color:var(--pink);min-width:70px;padding-top:2px;
}
.edu-details h4{font-size:13px;font-weight:500;margin-bottom:.3rem;}
.edu-details p{font-size:12px;color:var(--mid);}
.skill-pills{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.5rem;}
.pill{
  font-size:10px;letter-spacing:1px;text-transform:uppercase;
  padding:.3rem .8rem;
  background:var(--teal-pale);color:var(--teal);
  border:1px solid var(--teal-light);
}

/* ─── EXPERIENCE ─── */
#experience{
  background:var(--light);
  padding-top:64px;
  min-height:100vh;
}
.exp-inner{
  display:grid;grid-template-columns:1fr 1fr;
  min-height:calc(100vh - 64px);
}
.exp-left{
  padding:4rem 3rem 4rem 5rem;
  border-right:1px solid var(--border);
  background:var(--white);
  position:relative;
  display:flex;flex-direction:column;gap:2.5rem;
}
.exp-vert{
  position:absolute;left:1.5rem;top:50%;
  transform:translateY(-50%) rotate(-90deg);
  font-family:'Bebas Neue',cursive;
  font-size:5.5rem;letter-spacing:6px;
  color:var(--border);white-space:nowrap;pointer-events:none;
}
.exp-heading{
  font-family:'Bebas Neue',cursive;
  font-size:3.5rem;letter-spacing:2px;
  color:var(--dark);line-height:.95;
}
.exp-img-block{
  width:100%;height:180px;
  background:var(--pink-pale);
  position:relative;overflow:hidden;
}
.exp-img-inner{
  position:absolute;left:0;top:0;bottom:0;width:50%;
  background-image:url('images/jjk-left.jpg');
  background-size:cover;
  background-position:center;
}
.exp-img-right{
  position:absolute;right:0;top:0;bottom:0;width:50%;
  background-image:url('images/jjk-right.jpg');
  background-size:cover;
  background-position:center;
}
.exp-item{
  padding:1rem 0;border-bottom:1px solid var(--border);
  display:flex;gap:1.5rem;
}
.exp-date{
  font-size:10px;letter-spacing:2px;color:var(--pink);
  min-width:80px;padding-top:2px;text-transform:uppercase;
}
.exp-content h4{font-size:13px;font-weight:500;margin-bottom:.2rem;}
.exp-content p{font-size:12px;color:var(--mid);line-height:1.6;}
.exp-tag{
  display:inline-block;
  font-size:10px;letter-spacing:1px;text-transform:uppercase;
  background:var(--pink-pale);color:var(--pink);
  padding:.2rem .6rem;margin-top:.4rem;
}

/* Projects panel */
.exp-right{
  padding:4rem 3rem 4rem 3rem;
  display:flex;flex-direction:column;gap:2rem;
  position:relative;
}
.proj-heading{
  font-family:'Bebas Neue',cursive;
  font-size:3.5rem;letter-spacing:2px;
  color:var(--dark);line-height:.95;
}
.proj-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:1rem;
}
.proj-card{
  background:var(--white);
  padding:1.2rem;
  border:1px solid var(--border);
  position:relative;overflow:hidden;
  transition:border-color .2s;
}
.proj-card:hover{border-color:var(--pink);}
.proj-card-img{
  width:100%;height:90px;
  margin-bottom:.8rem;position:relative;overflow:hidden;
}
.proj-card:nth-child(1) .proj-card-img{background:var(--teal-light);}
.proj-card:nth-child(2) .proj-card-img{background:var(--pink-pale);}
.proj-card:nth-child(3) .proj-card-img{background:var(--pink-light);}
.proj-card:nth-child(4) .proj-card-img{background:var(--teal-pale);}
.proj-card-dot{
  position:absolute;top:8px;left:8px;
  width:8px;height:8px;background:var(--pink);
}
.proj-card h5{font-size:12px;font-weight:500;margin-bottom:.3rem;}
.proj-card p{font-size:11px;color:var(--mid);line-height:1.5;}
.proj-card-bar{
  width:30px;height:3px;background:var(--teal);margin-top:.6rem;
}
.proj-cta{
  margin-top:auto;
  display:inline-block;
  font-size:11px;letter-spacing:2px;text-transform:uppercase;
  background:var(--dark);color:#fff;
  padding:.8rem 2rem;text-decoration:none;
  transition:background .2s;cursor:pointer;border:none;
  align-self:flex-start;
}
.proj-cta:hover{background:var(--pink);}

/* ─── CONTACT / FOOTER ─── */
#contact{
  background:var(--dark);
  padding:6rem 5rem;
  display:grid;grid-template-columns:1fr 1fr;gap:4rem;
  align-items:center;
}
.contact-kicker{
  font-size:10px;letter-spacing:3px;text-transform:uppercase;
  color:var(--teal);margin-bottom:1rem;
}
.contact-heading{
  font-family:'Bebas Neue',cursive;
  font-size:5rem;letter-spacing:3px;
  color:var(--white);line-height:.9;
  margin-bottom:1.5rem;
}
.contact-sub{font-size:13px;color:#aaa;line-height:1.8;max-width:380px;}
.contact-bar{
  width:60px;height:4px;
  background:var(--pink);margin-top:2rem;
}
.contact-right{display:flex;flex-direction:column;gap:1rem;}
.contact-input{
  background:transparent;
  border:none;border-bottom:1px solid #444;
  padding:.8rem 0;font-size:13px;
  font-family:'DM Sans',sans-serif;
  color:var(--white);outline:none;
  transition:border-color .2s;
}
.contact-input::placeholder{color:#555;letter-spacing:1px;}
.contact-input:focus{border-color:var(--teal);}
.contact-textarea{
  background:transparent;
  border:none;border-bottom:1px solid #444;
  padding:.8rem 0;font-size:13px;
  font-family:'DM Sans',sans-serif;
  color:var(--white);outline:none;
  resize:none;height:80px;
  transition:border-color .2s;
}
.contact-textarea::placeholder{color:#555;letter-spacing:1px;}
.contact-textarea:focus{border-color:var(--teal);}
.contact-submit{
  background:var(--pink);color:#fff;
  border:none;padding:.9rem 2.5rem;
  font-size:11px;letter-spacing:3px;text-transform:uppercase;
  font-family:'DM Sans',sans-serif;
  cursor:pointer;transition:background .2s;align-self:flex-start;
  margin-top:.5rem;
}
.contact-submit:hover{background:#c93d63;}
.footer-bar{
  background:var(--dark);
  border-top:1px solid #2a2a2a;
  padding:1.5rem 5rem;
  display:flex;justify-content:space-between;align-items:center;
}
.footer-copy{font-size:11px;color:#555;letter-spacing:1px;}
.footer-socials{display:flex;gap:1.5rem;}
.footer-socials a{
  font-size:11px;letter-spacing:1px;text-transform:uppercase;
  color:#555;text-decoration:none;transition:color .2s;
}
.footer-socials a:hover{color:var(--teal);}

/* ─── SCROLL ANIMATIONS ─── */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease;}
.reveal.visible{opacity:1;transform:translateY(0);}
.reveal-left{opacity:0;transform:translateX(-28px);transition:opacity .7s ease,transform .7s ease;}
.reveal-left.visible{opacity:1;transform:translateX(0);}

/* Pink decorative squares that float */
.deco-sq{position:absolute;background:var(--pink);opacity:.12;pointer-events:none;}

/* ─── RESPONSIVE ─── */
/* Tablets & Small Laptops (768px - 1024px) */
@media(max-width:1024px){
  .nav-menu{display:none;}
  nav{padding:1rem 2rem;}
  .nav-logo{font-size:1.2rem;}
  .nav-links{gap:1.5rem;}
  .nav-links a{font-size:10px;}
  
  section{min-height:auto;}
  
  #cover{padding-top:64px;}
  .cover-left{padding:2.5rem 2rem 2.5rem 3rem; border-right:none;}
  .cover-right{padding:2.5rem 2rem;}
  .big-title{font-size:7rem;line-height:.8;}
  .side-text-left{font-size:8px;}
  .side-text-right{font-size:8px;}
  
  .about-inner, .exp-inner{grid-template-columns:1fr;}
  .about-left{padding:3rem 2rem 3rem 2rem; border-right:none; border-bottom:1px solid var(--border);}
  .about-right{padding:2.5rem 2rem;}
  .about-heading, .edu-heading{font-size:2.8rem;}
  .section-vert-label{font-size:3.5rem;}
  
  .exp-left{padding:3rem 2rem 3rem 2rem; border-right:none; border-bottom:1px solid var(--border);}
  .exp-right{padding:2.5rem 2rem;}
  .exp-heading, .proj-heading{font-size:2.8rem;}
  .exp-vert{font-size:3.5rem;}
  
  .proj-grid{grid-template-columns:1fr 1fr;}
  
  #contact{grid-template-columns:1fr; padding:4rem 2rem; gap:2.5rem;}
  .contact-heading{font-size:3.5rem;}
  
  .footer-bar{padding:1.5rem 2rem;}
  .footer-socials{gap:1rem;}
}

/* Mobile Landscape & Small Tablets (480px - 768px) */
@media(max-width:768px){
  html{font-size:14px;}
  .nav-menu{display:none;}
  nav{padding:.8rem 1.5rem;}
  .nav-logo{font-size:1.1rem;}
  .nav-links{gap:1rem;}
  .nav-links a{font-size:9px; letter-spacing:1.5px;}
  .nav-cta{padding:.5rem 1rem; font-size:10px;}
  
  section{min-height:auto; padding-top:0;}
  
  #cover{grid-template-columns:1fr; padding-top:64px;}
  .cover-left{padding:2rem 1.5rem; border-right:none; border-bottom:1px solid var(--border);}
  .cover-right{padding:2rem 1.5rem;}
  .cover-header-labels{font-size:8px;}
  .big-title{font-size:5rem; line-height:.75; letter-spacing:2px;}
  .teal-block{width:120px; height:160px;}
  .photo-placeholder{width:120px; height:160px;}
  .pink-bar{width:40px; height:10px; bottom:32%; left:35%;}
  .side-text-left, .side-text-right{font-size:7px;}
  .title-wrap{margin:1rem 0;}
  .cover-bottom{padding-top:.5rem;}
  .cover-tag{font-size:10px;}
  .cover-tagline{font-size:12px;}
  
  .toc-title{font-size:8px;}
  .toc-item{font-size:12px; padding:.5rem 0;}
  .toc-num{font-size:10px;}
  .cover-image-thumb{height:140px;}
  .toc-label{font-size:9px;}
  
  .about-inner, .exp-inner{grid-template-columns:1fr;}
  .about-left{padding:2rem 1.5rem; border-right:none; border-bottom:1px solid var(--border);}
  .about-right{padding:2rem 1.5rem;}
  .section-vert-label{font-size:2.5rem; letter-spacing:3px;}
  .section-tag{font-size:9px;}
  .about-heading, .edu-heading{font-size:2.2rem; letter-spacing:1px;}
  .about-text{font-size:12px; max-width:100%;}
  .about-img-block, .edu-img-block{height:140px;}
  .about-stats{flex-direction:column; gap:1.5rem;}
  .stat-num{font-size:1.8rem;}
  .stat-label{font-size:10px;}
  .edu-item{padding:.6rem 0; gap:1rem;}
  .edu-year{font-size:9px; min-width:60px;}
  .edu-details h4{font-size:12px;}
  .edu-details p{font-size:11px;}
  .skill-pills{gap:.4rem;}
  .pill{font-size:9px; padding:.25rem .6rem;}
  
  .exp-left{padding:2rem 1.5rem; border-right:none; border-bottom:1px solid var(--border);}
  .exp-right{padding:2rem 1.5rem;}
  .exp-vert{font-size:2.5rem;}
  .exp-heading, .proj-heading{font-size:2.2rem;}
  .exp-img-block{height:140px;}
  .exp-item{padding:.7rem 0; gap:1rem;}
  .exp-date{font-size:9px; min-width:60px;}
  .exp-content h4{font-size:12px;}
  .exp-content p{font-size:11px;}
  .exp-tag{font-size:9px; padding:.15rem .5rem; margin-top:.3rem;}
  
  .proj-grid{grid-template-columns:1fr; gap:.8rem;}
  .proj-card{padding:1rem;}
  .proj-card-img{height:70px; margin-bottom:.6rem;}
  .proj-card h5{font-size:11px;}
  .proj-card p{font-size:10px;}
  .proj-card-bar{width:25px; height:2px; margin-top:.5rem;}
  .proj-cta{font-size:10px; padding:.6rem 1.5rem;}
  
  #contact{grid-template-columns:1fr; padding:2.5rem 1.5rem; gap:2rem; min-height:auto;}
  .contact-left{min-width:100%;}
  .contact-right{min-width:100%;}
  .contact-kicker{font-size:9px;}
  .contact-heading{font-size:2.2rem; letter-spacing:1px;}
  .contact-sub{font-size:12px; max-width:100%;}
  .contact-bar{width:40px; height:3px;}
  .contact-input, .contact-textarea{font-size:12px; padding:.6rem 0;}
  .contact-submit{font-size:10px; padding:.7rem 1.5rem;}
  
  .footer-bar{padding:1.2rem 1.5rem; flex-direction:column; gap:1rem; text-align:center;}
  .footer-copy{font-size:10px;}
  .footer-socials{gap:.8rem;}
  .footer-socials a{font-size:10px;}
}

/* Mobile Portrait (max-width:480px) */
@media(max-width:480px){
  html{font-size:13px;}
  
  /* Mobile Nav Hamburger */
  .nav-menu{display:flex;}
